<?xml version="1.0" encoding="utf-8"?>
<modification>
	<name>Kotlyars Catalog Foundation</name>
	<code>kotlyars_catalog_foundation</code>
	<version>1.0.0</version>
	<author>OpenAI Codex</author>
	<link>https://kotlyars.com</link>

	<file path="admin/controller/catalog/product.php">
		<operation>
			<ignoreif><![CDATA[
			$this->model_extension_module_kotlyars_catalog_foundation->saveProductFoundation($product_id, $this->request->post);
			]]></ignoreif>
			<search><![CDATA[
			$this->model_catalog_product->addProduct($this->request->post);
			]]></search>
			<add position="replace"><![CDATA[
			$product_id = $this->model_catalog_product->addProduct($this->request->post);

			$this->load->model('extension/module/kotlyars_catalog_foundation');
			$this->model_extension_module_kotlyars_catalog_foundation->saveProductFoundation($product_id, $this->request->post);
			]]></add>
		</operation>
		<operation>
			<ignoreif><![CDATA[
			$this->model_extension_module_kotlyars_catalog_foundation->saveProductFoundation((int)$this->request->get['product_id'], $this->request->post);
			]]></ignoreif>
			<search><![CDATA[
			$this->model_catalog_product->editProduct($this->request->get['product_id'], $this->request->post);
			]]></search>
			<add position="after"><![CDATA[

			$this->load->model('extension/module/kotlyars_catalog_foundation');
			$this->model_extension_module_kotlyars_catalog_foundation->saveProductFoundation((int)$this->request->get['product_id'], $this->request->post);
			]]></add>
		</operation>
		<operation>
			<ignoreif><![CDATA[
		$data['kotlyars_catalog_foundation_tab'] = $this->load->controller('extension/module/kotlyars_catalog_foundation/productTab', array(
			]]></ignoreif>
			<search><![CDATA[
		// Filters
			]]></search>
			<add position="before"><![CDATA[

		$this->load->language('extension/module/kotlyars_catalog_foundation');
		$data['tab_kotlyars_catalog_foundation'] = $this->language->get('tab_kotlyars_catalog_foundation');
		$data['kotlyars_catalog_foundation_tab'] = $this->load->controller('extension/module/kotlyars_catalog_foundation/productTab', array(
			'product_id' => isset($this->request->get['product_id']) ? (int)$this->request->get['product_id'] : 0,
			'post' => $this->request->post,
			'product_category' => $categories,
			'errors' => isset($this->error['kotlyars_catalog_foundation']) ? $this->error['kotlyars_catalog_foundation'] : array()
		));
			]]></add>
		</operation>
		<operation>
			<ignoreif><![CDATA[
		$foundation_errors = $this->model_extension_module_kotlyars_catalog_foundation->validateProductFoundation($this->request->post);
			]]></ignoreif>
			<search><![CDATA[
		if ($this->request->post['product_seo_url']) {
			]]></search>
			<add position="before"><![CDATA[
		$this->load->model('extension/module/kotlyars_catalog_foundation');

		$foundation_errors = $this->model_extension_module_kotlyars_catalog_foundation->validateProductFoundation($this->request->post);

		if ($foundation_errors) {
			$this->error['kotlyars_catalog_foundation'] = $foundation_errors;
		}

			]]></add>
		</operation>
	</file>

	<file path="admin/view/template/catalog/product_form.twig">
		<operation>
			<ignoreif><![CDATA[
            <li><a href="#tab-kotlyars-catalog-foundation" data-toggle="tab">{{ tab_kotlyars_catalog_foundation }}</a></li>
			]]></ignoreif>
			<search><![CDATA[
            <li><a href="#tab-links" data-toggle="tab">{{ tab_links }}</a></li>
			]]></search>
			<add position="after"><![CDATA[
            <li><a href="#tab-links" data-toggle="tab">{{ tab_links }}</a></li>
            <li><a href="#tab-kotlyars-catalog-foundation" data-toggle="tab">{{ tab_kotlyars_catalog_foundation }}</a></li>
			]]></add>
		</operation>
		<operation>
			<ignoreif><![CDATA[
            {{ kotlyars_catalog_foundation_tab }}
			]]></ignoreif>
			<search><![CDATA[
            <div class="tab-pane" id="tab-attribute">
			]]></search>
			<add position="before"><![CDATA[
            {{ kotlyars_catalog_foundation_tab }}
			]]></add>
		</operation>
	</file>
</modification>
