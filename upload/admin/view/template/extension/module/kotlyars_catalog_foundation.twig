{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-kotlyars-catalog-foundation" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
      <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
        <button type="button" class="close" data-dismiss="alert">&times;</button>
      </div>
    {% endif %}
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-sitemap"></i> {{ heading_title }}</h3>
      </div>
      <div class="panel-body">
        <form action="{{ action }}" method="post" id="form-kotlyars-catalog-foundation" class="form-horizontal">
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-status">{{ entry_status }}</label>
            <div class="col-sm-10">
              <select name="module_kotlyars_catalog_foundation_status" id="input-status" class="form-control">
                {% if module_kotlyars_catalog_foundation_status %}
                  <option value="1" selected="selected">{{ text_enabled }}</option>
                  <option value="0">{{ text_disabled }}</option>
                {% else %}
                  <option value="1">{{ text_enabled }}</option>
                  <option value="0" selected="selected">{{ text_disabled }}</option>
                {% endif %}
              </select>
            </div>
          </div>

          <table class="table table-bordered table-striped">
            <thead>
              <tr>
                <th>Registry</th>
                <th>Count</th>
              </tr>
            </thead>
            <tbody>
              <tr><td>Governed categories</td><td>{{ overview.category_count }}</td></tr>
              <tr><td>Attributes</td><td>{{ overview.attribute_count }}</td></tr>
              <tr><td>Extension-backed attributes</td><td>{{ overview.extension_attribute_count }}</td></tr>
              <tr><td>Core-backed attributes</td><td>{{ overview.core_attribute_count }}</td></tr>
              <tr><td>Filters</td><td>{{ overview.filter_count }}</td></tr>
              <tr><td>Product types</td><td>{{ overview.product_types }}</td></tr>
            </tbody>
          </table>
        </form>
      </div>
    </div>
  </div>
</div>
{{ footer }}
