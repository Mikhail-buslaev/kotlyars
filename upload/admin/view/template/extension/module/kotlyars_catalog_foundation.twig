{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <a href="{{ register_modification }}" data-toggle="tooltip" title="{{ button_register_modification }}" class="btn btn-info"><i class="fa fa-puzzle-piece"></i></a>
        <a href="{{ bootstrap_native_catalog }}" data-toggle="tooltip" title="{{ button_bootstrap_native_catalog }}" class="btn btn-warning"><i class="fa fa-sitemap"></i></a>
        <a href="{{ refresh_modifications }}" data-toggle="tooltip" title="{{ button_refresh_modifications }}" class="btn btn-default"><i class="fa fa-refresh"></i></a>
        <button type="submit" form="form-kotlyars-catalog-foundation" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
      <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
        <button type="button" class="close" data-dismiss="alert">&times;</button>
      </div>
    {% endif %}
    {% if success %}
      <div class="alert alert-success alert-dismissible"><i class="fa fa-check-circle"></i> {{ success }}
        <button type="button" class="close" data-dismiss="alert">&times;</button>
      </div>
    {% endif %}
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-sitemap"></i> {{ heading_title }}</h3>
      </div>
      <div class="panel-body">
        <form action="{{ action }}" method="post" id="form-kotlyars-catalog-foundation" class="form-horizontal">
          <div class="alert {% if modification_info %}alert-success{% else %}alert-warning{% endif %}">
            <i class="fa {% if modification_info %}fa-check-circle{% else %}fa-exclamation-circle{% endif %}"></i>
            {% if modification_info %}
              {{ text_modification_status_registered }}
            {% else %}
              {{ text_modification_status_missing }}
            {% endif %}
          </div>

          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-status">{{ entry_status }}</label>
            <div class="col-sm-10">
              <select name="module_kotlyars_catalog_foundation_status" id="input-status" class="form-control">
                {% if module_kotlyars_catalog_foundation_status %}
                  <option value="1" selected="selected">{{ text_enabled }}</option>
                  <option value="0">{{ text_disabled }}</option>
                {% else %}
                  <option value="1">{{ text_enabled }}</option>
                  <option value="0" selected="selected">{{ text_disabled }}</option>
                {% endif %}
              </select>
            </div>
          </div>

          <table class="table table-bordered table-striped">
            <thead>
              <tr>
                <th>Registry</th>
                <th>Count</th>
              </tr>
            </thead>
            <tbody>
              <tr><td>Governed leaves</td><td>{{ overview.leaf_count }}</td></tr>
              <tr><td>Attributes</td><td>{{ overview.attribute_count }}</td></tr>
              <tr><td>Ranges</td><td>{{ overview.range_count }}</td></tr>
              <tr><td>Native taxonomy nodes</td><td>{{ overview.native_category_node_count }}</td></tr>
              <tr><td>Mapped native categories</td><td>{{ overview.native_category_map_count }}</td></tr>
              <tr><td>Mapped native leaf categories</td><td>{{ overview.native_leaf_map_count }}</td></tr>
              <tr><td>Mapped native attribute groups</td><td>{{ overview.native_attribute_group_count }}</td></tr>
              <tr><td>Mapped native attributes</td><td>{{ overview.native_attribute_map_count }}</td></tr>
            </tbody>
          </table>
        </form>
      </div>
    </div>
  </div>
</div>
{{ footer }}
