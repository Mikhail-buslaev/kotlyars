								<option value="{{ times.name }}" selected="selected">{{ times.name }}</option>
								{% else %}
								<option value="{{ times.name }}">{{ times.name }}</option>
								{% endif %}
								{% endfor %}
							  </select>
							  </div>
							</div>

							<div class="form-group">
							  <label class="col-sm-2 control-label">{{ entry_bannerimage }}</label>
