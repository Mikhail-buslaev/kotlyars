						<li class="active"><a href="#tab-general" data-toggle="tab"><i class="fa fa-cog"></i> {{ tab_general }}</a></li>
						<li><a href="#tab-laguage" data-toggle="tab"><i class="fa fa-language"></i> {{ tab_laguage }}</a></li>
						<li><a href="#tab-color" data-toggle="tab"><i class="fa fa-magic"></i> {{ tab_color }}</a></li>
						<li><a href="#tab-customcss" data-toggle="tab"><i class="fa fa-code"></i> {{ tab_customcss }}</a></li>
						<li><a href="#tab-mail" data-toggle="tab"><i class="fa fa-envelope" aria-hidden="true"></i> {{ tab_mail }}</a></li>
						<li><a href="#tab-seourl" data-toggle="tab"><i class="fa fa-envelope" aria-hidden="true"></i> {{ tab_seourl }}</a></li>
					</ul>
					
					<div class="tab-content">
						<div class="tab-pane active" id="tab-general">
							<div class="form-group">
								<label class="col-sm-2 control-label">{{ entry_status }}</label>
								<div class="col-sm-9 btn-group" data-toggle="buttons">
									{% if tmdauction_status %}
									<label class="btn btn-primary active">
									  <input type="radio" name="tmdauction_status" value="1" checked="checked"> {{ text_enabled }}
									</label>
									{% else %}
									<label class="btn btn-primary">
										<input type="radio" name="tmdauction_status" value="1"> {{ text_enabled }}
									</label>
									{% endif %}
									{% if not tmdauction_status %}
									<label class="btn btn-primary active">
										<input type="radio" name="tmdauction_status" value="0" checked="checked"> {{ text_disabled }}
									</label>
									{% else %}
									<label class="btn btn-primary">
										<input type="radio" name="tmdauction_status" value="0"> {{ text_disabled }}
									</label>
									{% endif %}
								</div>              
							</div>
							
							<div class="form-group">
							  <label class="col-sm-2 control-label">{{ entry_limit }}</label>
							  <div class="col-sm-4">
							   <input type="number" name="tmdauction_limit" value="{{ tmdauction_limit }}" placeholder="{{ entry_limit }}"  class="form-control">
							  </div>
							  <label class="col-sm-2 control-label">{{ entry_auction_pro_limit }}</label>
							  <div class="col-sm-4">
							   <input type="number" name="tmdauction_auction_pro_limit" value="{{ tmdauction_auction_pro_limit }}" placeholder="{{ entry_auction_pro_limit }}"  class="form-control">
							  </div>
							</div>
							
							<div class="form-group">
