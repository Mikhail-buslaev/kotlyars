{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" id="submit" form="form-tmdauction" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a></div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-pencil"></i> {{ text_form }}</h3>
      </div>
      <div class="panel-body">
        <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-tmdauction" class="form-horizontal">
          <div class="form-group required">
            <label class="col-sm-2 control-label" for="input-product_id">{{ entry_name }}</label>
            <div class="col-sm-10">
                {% if pro_id %}
                <input type="text" value="{{ product_name }}" class="form-control" disabled="disabled"/>
                {% else %}
                <input type="text" name="product" value="" id="input-product_id" class="form-control" />
                <input type="hidden" name="product_id"/>
                {% endif %}
                {% if error_product_id %}
                <div class="text-danger">{{ error_product_id }}</div>
                {% endif %}
            </div>
          </div>
          <legend>{{ text_auction_completion }}</legend>
          <div class="form-group">
            <label class="col-sm-2 control-label"></label>
            <div class="col-sm-10">
              <div class="checkbox">
                <label>
                  {% if auto_finish == 1 %}
                  <input type="checkbox" name="auto_finish" value="1" checked="checked" /> {{ text_autofinish }}
                  {% else %}
                  <input type="checkbox" name="auto_finish" value="1" /> {{ text_autofinish }}
                  {% endif %}
                </label>
              </div>
            </div>
          </div>
          <legend>{{ text_auction_setting }}</legend>
          <div class="form-group">
            <label class="col-sm-2 control-label"></label>
            <div class="col-sm-10">
              <div class="checkbox">
                <label>
                  {% if active == 1 %}
                  <input type="checkbox" name="active" value="1" checked="checked" /> {{ text_active }}
                  {% else %}
                  <input type="checkbox" name="active" value="1" /> {{ text_active }}
                  {% endif %}
                </label>
              </div>
            </div>
          </div>
          <div class="form-group required">
            <label class="col-sm-2 control-label" for="input-start_time">{{ entry_start_time }}</label>
            <div class="col-sm-5">
              <div class="input-group datetime">
                <input type="text" name="start_time" value="{{ start_time }}" placeholder="YYYY-MM-DD HH:mm" data-date-format="YYYY-MM-DD HH:mm" id="input-start_time" class="form-control" />
                <span class="input-group-btn">
                <button class="btn btn-default" type="button"><i class="fa fa-calendar"></i></button>
                </span>
              </div>
              <span>{{ help_start_time }}</span>
              {% if error_start_time %}
              <div class="text-danger">{{ error_start_time }}</div>
              {% endif %}
            </div>
          </div>
          <div class="form-group required">
            <label class="col-sm-2 control-label" for="input-end_time">{{ entry_end_time }}</label>
            <div class="col-sm-5">
              <div class="input-group datetime">
                <input type="text" name="end_time" value="{{ end_time }}" placeholder="YYYY-MM-DD HH:mm" data-date-format="YYYY-MM-DD HH:mm" id="input-end_time" class="form-control" />
                <span class="input-group-btn">
                <button class="btn btn-default" type="button"><i class="fa fa-calendar"></i></button>
                </span></div>
                <span>{{ help_end_time }}</span>
              {% if error_end_time %}
              <div class="text-danger">{{ error_end_time }}</div>
              {% endif %}
            </div>
          </div>
          <div class="form-group required">
            <label class="col-sm-2 control-label" for="input-starting_bids">{{ entry_starting_bids }}</label>
            <div class="col-sm-10">
                <input type="text" name="starting_bids" value="{{ starting_bids }}" placeholder="{{ entry_starting_bids }}" id="input-starting_bids" class="form-control" />
                <span>{{ help_starting_bids }}</span>
              {% if error_starting_bids %}
              <div class="text-danger">{{ error_starting_bids }}</div>
              {% endif %}
            </div>
          </div>
          <div class="form-group" id="notrequired">
            <label class="col-sm-2 control-label" for="input-max_price">{{ entry_max_price }}</label>
            <div class="col-sm-10">
                <input type="text" name="max_price" value="{{ max_price }}" placeholder="{{ entry_max_price }}" id="input-max_price" class="form-control" />
                <span>{{ help_max_price }}</span>
              {% if error_max_price %}
              <div class="text-danger">{{ error_max_price }}</div>
              {% endif %}
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-minimum_quantity">{{ entry_min_quantity }}</label>
            <div class="col-sm-10">
                <input type="text" name="minimum_quantity" value="{{ minimum_quantity }}" placeholder="{{ entry_min_quantity }}" id="input-minimum_quantity" class="form-control" />
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-maximum_quantity">{{ entry_max_quantity }}</label>
            <div class="col-sm-10">
                <input type="text" name="maximum_quantity" value="{{ maximum_quantity }}" placeholder="{{ entry_max_quantity }}" id="input-maximum_quantity" class="form-control" />
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
  <script type="text/javascript">
    var dateToday = new Date();
    $('.datetime').datetimepicker({
      pickDate: true,
      pickTime: true,
      minDate: dateToday
    });
  </script>
  <script type="text/javascript">
    $(document).ready(function(){
      if($('input[name="auto_finish"]').prop("checked") == true){
        $('#notrequired').attr("class","form-group required");
      }
      $('input[name="auto_finish"]').click(function(){
        if($(this).prop("checked") == true){
          $('#notrequired').attr("class","form-group required");
        }else{
          $('#notrequired').attr("class","form-group");
        }
      });
    });
  </script> 
  <script type="text/javascript"><!--
$('input[name=\'product\']').autocomplete({
  'source': function(request, response) {
    $.ajax({
      url: 'index.php?route=catalog/product/autocomplete&user_token={{ user_token }}&filter_name=' +  encodeURIComponent(request),
      dataType: 'json',
      success: function(json) {
        response($.map(json, function(item) {
          return {
            label: item['name'],
            value: item['product_id']
          }
        }));
      }
    });
  },
  'select': function(item) {
    $('input[name=\'product\']').val(item['label']);
    $('input[name=\'product_id\']').val(item['value']);
  }
});
//--></script>
{{ footer }}
